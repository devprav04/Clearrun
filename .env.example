# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-50-char-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-server-ip,your-domain.com

# ── Database ──────────────────────────────────────────────────────────────────
# Use "sqlite" for quick local testing, "postgresql" for production
DB_ENGINE=postgresql
DB_NAME=cleanrun_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Celery / Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=CleanRun IMMS <your-email@gmail.com>

# ── Production Security (only active when DEBUG=False) ────────────────────────
# Set SECURE_HSTS_SECONDS > 0 only after confirming HTTPS works end-to-end
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
# Set True if HTTPS is terminated at Django (not at a proxy like nginx)
SECURE_SSL_REDIRECT=False
